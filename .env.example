# Nexora AI Finance — Environment Variables
# Copy this file to .env.local and fill in your values.
# All Databricks variables are optional — the app falls back to a local
# SQLite adapter (sql.js) pre-seeded from static files when they are absent.

# ─── Clerk Authentication (Commercial SaaS Foundation) ─────────────────────────
# When BOTH keys are set, the platform enforces authentication, organizations,
# RBAC, and tenant isolation. When absent, it runs as the original single-tenant
# demo (no auth) — fully backward compatible.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Auth routing (defaults shown; uncomment to override)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
# In the Clerk dashboard: enable Organizations (the tenant boundary). The active
# organization id becomes the tenant's client_id for data isolation.

# ─── Databricks Connection ────────────────────────────────────────────────────
# Workspace hostname — no https://, no trailing slash
# Example: adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_HOST=

# Personal Access Token — generate at:
# Workspace → Settings → Developer → Access Tokens
DATABRICKS_TOKEN=

# SQL Warehouse HTTP Path — found at:
# SQL Warehouses → [your warehouse] → Connection Details → HTTP Path
# Example: /sql/1.0/warehouses/abc1234def5678
DATABRICKS_HTTP_PATH=

# Unity Catalog name (default: nexora)
DATABRICKS_CATALOG=nexora

# Schema/database within the catalog (default: finance)
DATABRICKS_SCHEMA=finance

# ─── AI Agents (optional — enables real Claude responses) ────────────────────
ANTHROPIC_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Nexora AI Finance
NEXT_PUBLIC_APP_VERSION=1.0.0
NODE_ENV=development
