ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Phase 3+: OpenAI (alternative AI provider)
# OPENAI_API_KEY=your_openai_api_key_here

# App
NEXT_PUBLIC_APP_NAME=Nexora AI Finance
NEXT_PUBLIC_APP_VERSION=1.0.0
